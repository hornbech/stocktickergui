# =============================================================================
# Stock Overview — Environment Configuration
# =============================================================================
# Copy this file to .env and edit the values:
#   cp .env.example .env
#
# Docker Compose automatically reads .env from the project root.
# =============================================================================

# --- Authentication ---
# Set a password to protect the dashboard behind a login screen.
# Leave empty (or remove) to disable authentication entirely.
# Minimum 8 characters when enabled.
DASHBOARD_PASSWORD=

# --- Auth Bypass (optional) ---
# Allow a specific hostname to skip authentication.
# Useful for hosting a public demo alongside a private instance.
# Example: AUTH_BYPASS_HOST=demo.hhornbech.dk
AUTH_BYPASS_HOST=

# --- Session Secret (optional) ---
# Secret used to sign session cookies. If not set, a random secret is
# generated on each startup, which means sessions are lost on restart.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=
